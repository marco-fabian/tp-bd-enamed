# Variáveis de ambiente do TP. Copia esse arquivo pra .env e ajusta se precisar.


# Banco SQLite (o ETL cria esse arquivo)
DATABASE_URL=sqlite:///data/processed/enamed.db
DB_PATH=data/processed/enamed.db


# Caminhos dos dados (só mexer se quiser outra estrutura de pasta)
DATA_RAW_DIR=data/raw
DATA_EXTRACTED_DIR=data/extracted
DATA_PROCESSED_DIR=data/processed
